# Database
DB_PATH=./isa.db

# Scanner
SCAN_ROOT=C:/Users        # Windows default scan path
MAX_SCAN_DEPTH=10         # Kitni deep scan karein
SKIP_SYSTEM_FOLDERS=true  # System folders skip karein

# AI Engine (Phase 3 mein use hoga)
AI_API_KEY=your_api_key_here
AI_ENABLED=false          # Phase 1 mein off rakhein

# App
DEBUG=true
LOG_LEVEL=INFO
